<mvc:View controllerName="workflowcontext.controller.workflowcontext"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:form="sap.ui.layout.form"
    xmlns:table="sap.ui.table">
   <f:FlexibleColumnLayout
    id="fcl"
    layout="ThreeColumnsMidExpanded">
    <!-- Begin Column -->

    <f:beginColumnPages>
        <Page title="Workflow Instances">
            <List
                id="instanceList"
                items="{instances>/}"
                mode="SingleSelectMaster"
                selectionChange=".onInstanceSelect">

                <ObjectListItem
                    title="{instances>businessKey}"
                    number="{instances>status}"
                    intro="{instances>startedBy}"
                    type="Active"/>
            </List>
        </Page>
    </f:beginColumnPages>

    <!-- Middle Column -->

    <f:midColumnPages>
        <Page title="Workflow Header">
            <form:Form editable="false">
                <form:layout>
                    <form:ResponsiveGridLayout
                        labelSpanXL="3"
                        labelSpanL="3"
                        labelSpanM="3"
                        columnsXL="1"
                        columnsL="1"
                        columnsM="1"/>
                </form:layout>

                <form:formContainers>
                    <form:FormContainer>

                        <form:formElements>

                            <form:FormElement label="Business Key">
                                <form:fields>
                                    <Text text="{selectedHeader>/businessKey}"/>
                                </form:fields>
                            </form:FormElement>

                            <form:FormElement label="Status">
                                <form:fields>
                                    <ObjectStatus text="{selectedHeader>/status}"/>
                                </form:fields>
                            </form:FormElement>

                            <form:FormElement label="Started By">
                                <form:fields>
                                    <Text text="{selectedHeader>/startedBy}"/>
                                </form:fields>
                            </form:FormElement>

                            <form:FormElement label="Started At">
                                <form:fields>
                                    <Text text="{path: 'selectedHeader>/startedAt', formatter: '.formatter.formatDateTime'}"/>
                                </form:fields>
                            </form:FormElement>

                            <form:FormElement label="Definition">
                                <form:fields>
                                    <Text text="{selectedHeader>/definitionId}"/>
                                </form:fields>
                            </form:FormElement>

                            <form:FormElement label="Project">
                                <form:fields>
                                    <Text text="{selectedHeader>/projectId}"/>
                                </form:fields>
                            </form:FormElement>

                            <form:FormElement label="Project Version">
                                <form:fields>
                                    <Text text="{selectedHeader>/projectVersion}"/>
                                </form:fields>
                            </form:FormElement>

                        </form:formElements>

                    </form:FormContainer>

                </form:formContainers>

            </form:Form>
        </Page>
    </f:midColumnPages>

    <!-- End Column -->
    <f:endColumnPages>
        <Page title="Workflow Context">

            <Panel
                id="purchaseHeaderPanel"
                expandable="true"
                expanded="true"
                class="sapUiNoMargin">

                <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Purchase Header Details"/>
                    </OverflowToolbar>
                </headerToolbar>

                <content>

                    <form:SimpleForm
                        id="purchaseHeaderForm"
                        editable="false"
                        layout="ResponsiveGridLayout"
                        columnsXL="2"
                        columnsL="2"
                        columnsM="1"
                        labelSpanXL="3"
                        labelSpanL="3"
                        labelSpanM="3">

                        <!-- Row 1 -->

                        <Label text="Purchase No"/>
                        <Text text="{purchaseHeader>/PurchaseNo_PurchaseNo}"/>

                        <Label text="Description"/>
                        <Text text="{purchaseHeader>/Description}"/>

                        <!-- Row 2 -->

                        <Label text="Purchase Category"/>
                        <Text text="{purchaseHeader>/Purcahse_Catag}"/>

                        <Label text="Purchase Group"/>
                        <Text text="{purchaseHeader>/Purchase_Group}"/>

                        <!-- Row 3 -->

                        <Label text="Tender Type"/>
                        <Text text="{purchaseHeader>/Type_Ten}"/>

                        <Label text="Scope"/>
                        <Text text="{purchaseHeader>/Scope}"/>

                        <!-- Row 4 -->

                        <Label text="Estimated Time"/>
                        <Text text="{purchaseHeader>/Est_Time}"/>

                        <Label text="Estimated Time By"/>
                        <Text text="{purchaseHeader>/Est_Time_By}"/>

                        <!-- Row 5 -->

                        <Label text="Budget Amount"/>
                        <Text text="{purchaseHeader>/Amt_Budget}"/>

                        <Label text="Expected Amount"/>
                        <Text text="{purchaseHeader>/Exp_tot_Amt}"/>

                        <!-- Row 6 -->

                        <Label text="Total Amount"/>
                        <Text text="{purchaseHeader>/Tot_Amt}"/>

                        <Label text="GST %"/>
                        <Text text="{purchaseHeader>/GST_Percent}"/>

                        <!-- Row 7 -->

                        <Label text="GST Value"/>
                        <Text text="{purchaseHeader>/GST_Vale}"/>

                        <Label text="Expected GST"/>
                        <Text text="{purchaseHeader>/Exp_GST_Set}"/>

                        <!-- Row 8 -->

                        <Label text="Landed Cost"/>
                        <Text text="{purchaseHeader>/Exp_Landed}"/>

                        <Label text="Landed Cost (Words)"/>
                        <Text text="{purchaseHeader>/EXP_Landed_Des}"/>

                        <!-- Row 9 -->

                        <Label text="Created By"/>
                        <Text text="{purchaseHeader>/createdBy}"/>

                        <Label text="Created On"/>
                        <Text
                            text="{
                                path:'purchaseHeader>/createdAt',
                                formatter:'.formatter.formatSAPDate'
                            }"/>
                            

                        <!-- Row 10 -->

                        <Label text="Modified By"/>
                        <Text text="{purchaseHeader>/modifiedBy}"/>

                        <Label text="Modified On"/>
                        <Text
                            text="{
                                path:'purchaseHeader>/modifiedAt',
                                formatter:'.formatter.formatSAPDate'
                            }"/>

                    </form:SimpleForm>

                </content>

            </Panel>

            <Panel
                id="customDetailsPanel"
                expandable="true"
                expanded="true"
                class="sapUiNoMargin">

                 <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Custom Details"/>
                    </OverflowToolbar>
                </headerToolbar>

      
            <form:SimpleForm
                editable="false"
                layout="ResponsiveGridLayout"
                columnsXL="2"
                columnsL="2"
                columnsM="1"
                labelSpanXL="3"
                labelSpanL="3"
                labelSpanM="3">

                <Label text="Employee Code"/>
                <Text text="{custom>/emp_code}"/>

                <Label text="Employee Name"/>
                <Text text="{custom>/emp_name}"/>

                <Label text="Email"/>
                <Text text="{custom>/email_id}"/>

                <Label text="Authorization"/>
                <Text text="{custom>/auth_l}"/>

                <Label text="Level"/>
                <Text text="{custom>/level}"/>

                <Label text="Next Level"/>
                <Text text="{custom>/next_level}"/>

                <Label text="Amount"/>
                <Text text="{custom>/amount_inr}"/>

                <Label text="Workflow Instance"/>
                <Text text="{custom>/wf_instanceid}"/>

            </form:SimpleForm>
        </Panel>


        <Panel
                id="commentTablePanel"
                expandable="true"
                expanded="true"
                class="sapUiNoMargin">

                 <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Comments"/>
                    </OverflowToolbar>
                </headerToolbar>

            <table:Table
                id="commentTable"
                rows="{commentTable>/items}"
                selectionMode="None"
                width="100%"
                class="sapUiSmallMarginTop sapUiSmallMarginBottom">

                <table:columns>

                    <table:Column width="8rem">
                        <Label text="Status"/>
                        <table:template>
                            <Text text="{commentTable>Status}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="8rem">
                        <Label text="Employee Code"/>
                        <table:template>
                            <Text text="{commentTable>Emp_Code}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="12rem">
                        <Label text="Employee Name"/>
                        <table:template>
                            <Text text="{commentTable>Emp_name}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="8rem">
                        <Label text="Authorization"/>
                        <table:template>
                            <Text text="{commentTable>Emp_Auth_l}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="12rem">
                        <Label text="Comment"/>
                        <table:template>
                            <Input
                                value="{commentTable>comments}"
                                editable="true"
                                liveChange=".onCommentChange"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="10rem">
                        <Label text="Date"/>
                        <table:template>
                            <Text
                                text="{
                                    path:'commentTable>stamp',
                                    formatter:'.formatter.formatDateTime'
                                }"
                                wrapping="false"/>
                        </table:template>
                    </table:Column>

                </table:columns>

            </table:Table>
            </Panel>


        <Panel
                id="approvalTablePanel"
                expandable="true"
                expanded="true"
                class="sapUiNoMargin">

                 <headerToolbar>
                    <OverflowToolbar>
                        <Title text="Approval Tables"/>
                    </OverflowToolbar>
                </headerToolbar>

            <table:Table
            id="approvalTable1"
            rows="{approvalTable1>/results}"
            selectionMode="None"
            width="100%"
            class="sapUiSmallMarginTop sapUiSmallMarginBottom">
            
                <table:extension>
                    <OverflowToolbar>
                        <Title text="PO Approval list 1" level="H3"/>
                        <ToolbarSpacer/>
                        <Button text="Refresh" press=".onRefresh"/>
                    </OverflowToolbar>
                </table:extension>

                <table:columns>

                    <table:Column width="8rem">
                        <Label text="Status"/>
                        <table:template>
                            <Text text="{approvalTable1>Status}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="8rem">
                        <Label text="Employee Code"/>
                        <table:template>
                            <Text text="{approvalTable1>Emp_Code}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="5rem">
                        <Label text="Next Level"/>
                        <table:template>
                            <Text text="{approvalTable1>Next_level}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="12rem">
                        <Label text="Employee Name"/>
                        <table:template>
                            <Text text="{approvalTable1>Emp_name}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="8rem">
                        <Label text="Employee Auth"/>
                        <table:template>
                            <Text text="{approvalTable1>Emp_Auth_l}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="5rem">
                        <Label text="Level"/>
                        <table:template>
                            <Text text="{approvalTable1>Level}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="18rem">
                        <Label text="Designation"/>
                        <table:template>
                            <Text text="{approvalTable1>Emp_Desg}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="18rem">
                        <Label text="Employee Email"/>
                        <table:template>
                            <Text text="{approvalTable1>Emp_email}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                </table:columns>

            </table:Table>


            <table:Table
            id="approvalTable2"
            rows="{approvalTable2>/results}"
            selectionMode="None"
            width="100%"
            class="sapUiSmallMarginTop sapUiSmallMarginBottom">

                

                <table:extension>
                    <OverflowToolbar>
                        <Title text="PO Approval list 2" level="H3"/>
                        <ToolbarSpacer/>
                        <Button text="Refresh" press=".onRefresh"/>
                    </OverflowToolbar>
                </table:extension>

                <table:columns>

                    <table:Column width="8rem">
                        <Label text="Status"/>
                        <table:template>
                            <Text text="{approvalTable2>Status}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="8rem">
                        <Label text="Employee Code"/>
                        <table:template>
                            <Text text="{approvalTable2>Emp_Code}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="5rem">
                        <Label text="Next Level"/>
                        <table:template>
                            <Text text="{approvalTable2>Next_level}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="12rem">
                        <Label text="Employee Name"/>
                        <table:template>
                            <Text text="{approvalTable2>Emp_name}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="8rem">
                        <Label text="Employee Auth"/>
                        <table:template>
                            <Text text="{approvalTable2>Emp_Auth_l}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="5rem">
                        <Label text="Level"/>
                        <table:template>
                            <Text text="{approvalTable2>Level}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="18rem">
                        <Label text="Designation"/>
                        <table:template>
                            <Text text="{approvalTable2>Emp_Desg}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="18rem">
                        <Label text="Employee Email"/>
                        <table:template>
                            <Text text="{approvalTable2>Emp_email}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                </table:columns>

            </table:Table>
            </Panel>
        </Page>
    </f:endColumnPages>

</f:FlexibleColumnLayout>
</mvc:View>