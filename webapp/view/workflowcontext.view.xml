<mvc:View controllerName="workflowcontext.controller.workflowcontext"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:form="sap.ui.layout.form"
    xmlns:table="sap.ui.table">
   <f:FlexibleColumnLayout
    id="fcl"
    layout="ThreeColumnsMidExpanded">
    <!-- Begin Column -->

    <f:beginColumnPages>
        <Page title="Workflow Instances">
            <List
                id="instanceList"
                items="{instances>/}"
                mode="SingleSelectMaster"
                selectionChange=".onInstanceSelect">

                <ObjectListItem
                    title="{instances>businessKey}"
                    number="{instances>status}"
                    intro="{instances>startedBy}"
                    type="Active"/>
            </List>
        </Page>
    </f:beginColumnPages>

    <!-- Middle Column -->

    <f:midColumnPages>
        <Page title="Workflow Header">
            <form:Form editable="false">
                <form:layout>
                    <form:ResponsiveGridLayout
                        labelSpanXL="3"
                        labelSpanL="3"
                        labelSpanM="3"
                        columnsXL="1"
                        columnsL="1"
                        columnsM="1"/>
                </form:layout>

                <form:formContainers>
                    <form:FormContainer>

                        <form:formElements>

                            <form:FormElement label="Business Key">
                                <form:fields>
                                    <Text text="{selectedHeader>/businessKey}"/>
                                </form:fields>
                            </form:FormElement>

                            <form:FormElement label="Status">
                                <form:fields>
                                    <ObjectStatus text="{selectedHeader>/status}"/>
                                </form:fields>
                            </form:FormElement>

                            <form:FormElement label="Started By">
                                <form:fields>
                                    <Text text="{selectedHeader>/startedBy}"/>
                                </form:fields>
                            </form:FormElement>

                            <form:FormElement label="Started At">
                                <form:fields>
                                    <Text text="{path: 'selectedHeader>/startedAt', formatter: '.formatter.formatDateTime'}"/>
                                </form:fields>
                            </form:FormElement>

                            <form:FormElement label="Definition">
                                <form:fields>
                                    <Text text="{selectedHeader>/definitionId}"/>
                                </form:fields>
                            </form:FormElement>

                            <form:FormElement label="Project">
                                <form:fields>
                                    <Text text="{selectedHeader>/projectId}"/>
                                </form:fields>
                            </form:FormElement>

                            <form:FormElement label="Project Version">
                                <form:fields>
                                    <Text text="{selectedHeader>/projectVersion}"/>
                                </form:fields>
                            </form:FormElement>

                        </form:formElements>

                    </form:FormContainer>

                </form:formContainers>

            </form:Form>
        </Page>
    </f:midColumnPages>

    <!-- End Column -->
    <f:endColumnPages>
        <Page title="Workflow Context">
            <table:Table
            id="approvalTable1"
            rows="{approvalTable1>/results}"
            selectionMode="None"
            width="100%"
            class="sapUiSmallMarginTop sapUiSmallMarginBottom">

                <table:extension>
                    <OverflowToolbar>
                        <Title text="PO Approval list 1" level="H3"/>
                        <ToolbarSpacer/>
                        <Button text="Refresh" press=".onRefresh"/>
                    </OverflowToolbar>
                </table:extension>

                <table:columns>

                    <table:Column width="8rem">
                        <Label text="Status"/>
                        <table:template>
                            <Text text="{approvalTable1>Status}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="8rem">
                        <Label text="Employee Code"/>
                        <table:template>
                            <Text text="{approvalTable1>Emp_Code}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="5rem">
                        <Label text="Next Level"/>
                        <table:template>
                            <Text text="{approvalTable1>Next_level}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="12rem">
                        <Label text="Employee Name"/>
                        <table:template>
                            <Text text="{approvalTable1>Emp_name}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="8rem">
                        <Label text="Employee Auth"/>
                        <table:template>
                            <Text text="{approvalTable1>Emp_Auth_l}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="5rem">
                        <Label text="Level"/>
                        <table:template>
                            <Text text="{approvalTable1>Level}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="18rem">
                        <Label text="Designation"/>
                        <table:template>
                            <Text text="{approvalTable1>Emp_Desg}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="18rem">
                        <Label text="Employee Email"/>
                        <table:template>
                            <Text text="{approvalTable1>Emp_email}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                </table:columns>

            </table:Table>


            <table:Table
            id="approvalTable2"
            rows="{approvalTable2>/results}"
            selectionMode="None"
            width="100%"
            class="sapUiSmallMarginTop sapUiSmallMarginBottom">

                <table:extension>
                    <OverflowToolbar>
                        <Title text="PO Approval list 2" level="H3"/>
                        <ToolbarSpacer/>
                        <Button text="Refresh" press=".onRefresh"/>
                    </OverflowToolbar>
                </table:extension>

                <table:columns>

                    <table:Column width="8rem">
                        <Label text="Status"/>
                        <table:template>
                            <Text text="{approvalTable2>Status}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="8rem">
                        <Label text="Employee Code"/>
                        <table:template>
                            <Text text="{approvalTable2>Emp_Code}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="5rem">
                        <Label text="Next Level"/>
                        <table:template>
                            <Text text="{approvalTable2>Next_level}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="12rem">
                        <Label text="Employee Name"/>
                        <table:template>
                            <Text text="{approvalTable2>Emp_name}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="8rem">
                        <Label text="Employee Auth"/>
                        <table:template>
                            <Text text="{approvalTable2>Emp_Auth_l}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="5rem">
                        <Label text="Level"/>
                        <table:template>
                            <Text text="{approvalTable2>Level}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="18rem">
                        <Label text="Designation"/>
                        <table:template>
                            <Text text="{approvalTable2>Emp_Desg}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                    <table:Column width="18rem">
                        <Label text="Employee Email"/>
                        <table:template>
                            <Text text="{approvalTable2>Emp_email}" wrapping="false"/>
                        </table:template>
                    </table:Column>

                </table:columns>

            </table:Table>
        </Page>
    </f:endColumnPages>

</f:FlexibleColumnLayout>
</mvc:View>